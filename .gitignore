# ============================================================
#  SpeechNotes — .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Environment / Secrets ──────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
google_credential.json
# Block any potential secret files that might be missed
*_secret*
*_key*
*_token*

# ── Testing ─────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
hypothesis/
.pytest_cache/
/coverage

# ── Directory Exclusions (User Requested) ──────────────────
# Only keep core source code (src, backend, web) and report
scripts/
tests/
legacy/
knowledge_base/
temporal_docs/
assets/
notas/
audio/
docs/internal/

# ── Node / Next.js ──────────────────────────────────────────
node_modules/
.next/
web/.next/
out/
/build
.swc/
.pnpm-debug.log*
pnpm-lock.yaml
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/app/generated/prisma

# ── Database ────────────────────────────────────────────────
web/prisma/dev.db
web/prisma/dev.db-journal

# ── IDEs / Editors ──────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.qodo/

# ── OS files ────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
Icon?
~$*

# ── Logs and temp files ────────────────────────────────────
*.log
*.tmp
*.cache
vad_debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Audio / Media (generated) ──────────────────────────────
*.wav
*.mp3

# ── Promo / Marketing assets ──────────────────────────────
SN-*.png
SN-*.jpg
SN-*.jpeg
SP-*.png
SP-*.jpg
SP-*.jpeg
promos/

# ── Report (only final PDF tracked) ────────────────────────
docs/report/
!docs/report/*.pdf

# ── VAD config ──────────────────────────────────────────────
.vad_config.json

# ── Docker ──────────────────────────────────────────────────
# (keep docker-compose.yml and Dockerfile)

# ── Vercel ──────────────────────────────────────────────────
.vercel

# ── Misc ────────────────────────────────────────────────────
requirements-agent.txt
# run_all scripts might be convenient to keep, but if strict:
# run_all.bat
# run_all.ps1
