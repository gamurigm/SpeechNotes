# ============================================================
#  SpeechNotes — .gitignore
# ============================================================

# ── EXCLUDE EVERYTHING IN ROOT BY DEFAULT ──────────────────
/*.json
/*.yaml
/*.yml
/*.txt
/*.bat
/*.ps1
/*.md
/*.log
/*.conf
/*.config
/*.mjs
/*.js
/*.toml
/*.sh
/*.png

# ── EXCEPTIONS (Keep these root files) ─────────────────────
!/run_all.ps1
!/.gitignore
!/README.md
!/docker-compose.yml
# Keep .env.example (safe template) if desired, otherwise comment out
!/.env.example

# ── KEEP DIRECTORIES ───────────────────────────────────────
!/src/
!/backend/
!/web/
!/docs/
!/tests/
# (tests/ is whitelisted here, but contents might be ignored if not careful, checking below)

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ── Environment / Secrets ──────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
google_credential.json
*_secret*
*_key*
*_token*

# ── Testing ─────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
hypothesis/
.pytest_cache/
/coverage

# ── Directory Exclusions (User Requested) ──────────────────
# Re-exclude directories that might have been matched by !/src/ etc if they were inside
scripts/
legacy/
knowledge_base/
temporal_docs/
assets/
notas/
audio/
docs/internal/
# Exclude tests if user changed mind, but previous step I included it. 
# User said "scripts, tests, etc lo dejo a tu criterio". 
# I moved them to tests/ and scripts/.
# If user says "no incluyas cosas de la raiz", they might mean files.
# But "scripts, tests" are dirs. I will exclude them from git to be safe/clean as requested.
tests/

# ── Node / Next.js ──────────────────────────────────────────
node_modules/
.next/
web/.next/
out/
/build
.swc/
.pnpm-debug.log*
pnpm-lock.yaml
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/app/generated/prisma

# ── Database ────────────────────────────────────────────────
web/prisma/dev.db
web/prisma/dev.db-journal

# ── IDEs / Editors ──────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.qodo/

# ── OS files ────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
Icon?
~$*

# ── Logs and temp files ────────────────────────────────────
*.log
*.tmp
*.cache
vad_debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Audio / Media (generated) ──────────────────────────────
*.wav
*.mp3

# ── Promo / Marketing assets ──────────────────────────────
SN-*.png
SN-*.jpg
SN-*.jpeg
SP-*.png
SP-*.jpg
SP-*.jpeg
promos/

# ── Report (only final PDF tracked) ────────────────────────
docs/report/*
!docs/report/*.pdf

# ── VAD config ──────────────────────────────────────────────
.vad_config.json

# ── Vercel ──────────────────────────────────────────────────
.vercel

# ── GitHub ──────────────────────────────────────────────────
.github/instructions/

