# Keep whisper/wisper-related files and audio; if you want to keep only those,
# uncomment the following block and adjust the patterns. Leaving commented is
# safer so the .gitignore is non-destructive by default.
#
# /*
# !/wisper.md
# !/wisper*
# !/audio/
# !/check_wav.py
# !/.gitignore
# */
