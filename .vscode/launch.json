{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Transcribir audio con Riva (EN streaming)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/python-clients/scripts/asr/transcribe_file.py",
      "console": "integratedTerminal",
      "args": [
        "--server", "grpc.nvcf.nvidia.com:443",
        "--use-ssl",
        "--metadata", "function-id", "${env:RIVA_FUNCTION_ID}",
        "--metadata", "authorization", "Bearer ${env:NGC_API_KEY}",
        "--language-code", "en-US",
        "--model-name", "parakeet-1.1b-en-US-asr-streaming-silero-vad-sortformer",
        "--input-file", "${workspaceFolder}/audio/mi_audio.wav"
      ],
      "env": {
        "NGC_API_KEY": "${env:NGC_API_KEY}",
        "RIVA_FUNCTION_ID": "${env:RIVA_FUNCTION_ID}"
      }
    },
    {
      "name": "Health Check ASR",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/python-clients/scripts/asr/health_check_asr.py",
      "console": "integratedTerminal",
      "args": [
        "--server", "grpc.nvcf.nvidia.com:443",
        "--use-ssl",
        "--metadata", "function-id", "${env:RIVA_FUNCTION_ID}",
        "--metadata", "authorization", "Bearer ${env:NGC_API_KEY}",
        "--input-file", "${workspaceFolder}/audio/mi_audio.wav"
      ],
      "env": {
        "NGC_API_KEY": "${env:NGC_API_KEY}",
        "RIVA_FUNCTION_ID": "${env:RIVA_FUNCTION_ID}"
      }
    }
  ]
}
