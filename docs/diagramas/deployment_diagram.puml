@startuml
node "Máquina Cliente" as ClientNode {
  artifact "Aplicación Python" as App {
    component "src/cli/file.py" as CLI
    component "src/core/riva_client.py" as RivaClient
  }
}

node "Máquina Servidor (con GPU)" as ServerNode {
  collections "Docker" {
    node "Contenedor: riva-speech" as RivaContainer {
      artifact "Servicio Riva ASR" as ASRService
      artifact "Modelo Parakeet" as Model
    }
  }
}

ClientNode::App::RivaClient -right-> ServerNode::RivaContainer::ASRService : "gRPC (puerto 50051)"
@enduml