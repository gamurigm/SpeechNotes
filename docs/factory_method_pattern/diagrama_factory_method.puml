@startuml Factory_Method_Pattern_Exact
!define DIRECTION top to bottom
top to bottom direction

' =====================================
' PRODUCTO (ARRIBA-CENTRO)
' =====================================
interface AudioRecorder {
    + {abstract} record()
}

' =====================================
' PRODUCTOS CONCRETOS (ABAJO DEL PRODUCTO)
' =====================================
class MicrophoneStream {
    + record() : Generator[bytes]
}

class VADRecorder {
    + record() : bytes
}

class ContinuousRecorder {
    + record() : bytes
}

class BackgroundRecorder {
    + record() : Generator[bytes]
}

' Herencia - Productos heredan de AudioRecorder
AudioRecorder <|-- MicrophoneStream
AudioRecorder <|-- VADRecorder
AudioRecorder <|-- ContinuousRecorder
AudioRecorder <|-- BackgroundRecorder

' =====================================
' CREATOR (ARRIBA-DERECHA, conectado a Product)
' =====================================
abstract class RecorderFactory {
    # {abstract} create_recorder() : AudioRecorder
}

' Relación de uso entre AudioRecorder y RecorderFactory
AudioRecorder <.. RecorderFactory : <<use>>

' =====================================
' CONCRETE CREATORS (ABAJO DEL CREATOR)
' =====================================
class MicrophoneStreamRecorderFactory {
    + create_recorder() : MicrophoneStream
}

class VADRecorderFactory {
    + create_recorder() : VADRecorder
}

class ContinuousRecorderFactory {
    + create_recorder() : ContinuousRecorder
}

class BackgroundRecorderFactory {
    + create_recorder() : BackgroundRecorder
}

' Herencia - Creators concretos heredan del Creator abstracto
RecorderFactory <|-- MicrophoneStreamRecorderFactory
RecorderFactory <|-- VADRecorderFactory
RecorderFactory <|-- ContinuousRecorderFactory
RecorderFactory <|-- BackgroundRecorderFactory

' =====================================
' CREACIÓN - Creators concretos crean Productos concretos
' =====================================
MicrophoneStreamRecorderFactory ..> MicrophoneStream : <<create>>
VADRecorderFactory ..> VADRecorder : <<create>>
ContinuousRecorderFactory ..> ContinuousRecorder : <<create>>
BackgroundRecorderFactory ..> BackgroundRecorder : <<create>>

' =====================================
' PROVIDER (CENTRO SUPERIOR)
' =====================================
class AudioRecorderFactoryProvider {
    - {static} _factories : Dict
    + {static} create_recorder(RecorderType) : AudioRecorder
}

AudioRecorderFactoryProvider --|> RecorderFactory : uses

' =====================================
' CLIENT (DERECHA)
' =====================================
class Client {
}

AudioRecorderFactoryProvider --|> AudioRecorder : returns

note right of Client
    product = factoryMethod();
end note

@enduml
