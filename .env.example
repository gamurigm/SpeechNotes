# ──────────────────────────────────────────────────────────────
# SpeechNotes Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# NVIDIA NIM API Configuration
NVIDIA_API_KEY=nvapi-XXXXX
NVIDIA_EMBEDDING_API_KEY=nvapi-XXXXX
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY_THINKING=nvapi-XXXXX
NVIDIA_API_KEY_FAST=nvapi-XXXXX

# Model Configuration
CHAT_MODEL_THINKING=qwen/qwen3.5-397b-a17b
CHAT_MODEL_FAST=nvidia/nvidia-nemotron-nano-9b-v2
FORMATTER_MODEL=meta/llama-3.1-70b-instruct
EMBEDDING_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v2

# Agent Configuration
TEMPERATURE=0.2
TOP_P=0.7
MAX_TOKENS=8192

# MongoDB (local Docker or MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=agent_knowledge_base

# Backend
PORT=9443

# NextAuth (Frontend)
NEXTAUTH_URL=http://localhost:3006
NEXTAUTH_SECRET=your-secret-here

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
