# NVIDIA NIM API Configuration
NVIDIA_API_KEY=
NVIDIA_EMBEDDING_API_KEY=
NVIDIA_BASE_URL=
# Model Configuration
MODEL_NAME=deepseek-ai/deepseek-v3.1-terminus
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Agent Configuration
TEMPERATURE=0.2
TOP_P=0.7
MAX_TOKENS=8192

# Transcription Integration
TRANSCRIPTIONS_SOURCE_DIR=notas
TRANSCRIPTIONS_PROCESSED_DIR=knowledge_base/transcriptions
AUTO_INDEX_TRANSCRIPTIONS=true
TRANSCRIPTION_CHUNK_SIZE=500
PRESERVE_ORIGINALS=true

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=agent_knowledge_base

# Frontend Configuration
# URL interna para el servidor Next.js (SSR)
API_URL=http://backend:8001
# URL pública para el cliente (Browser)
NEXT_PUBLIC_API_URL=http://localhost:8001
DATABASE_URL=file:./dev.db
