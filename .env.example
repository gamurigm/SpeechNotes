# ──────────────────────────────────────────────────────────────
# SpeechNotes Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# NVIDIA NIM API Configuration
NVIDIA_API_KEY=nvapi-XXXXX
NVIDIA_EMBEDDING_API_KEY=nvapi-XXXXX
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY_THINKING=nvapi-XXXXX
NVIDIA_API_KEY_FAST=nvapi-XXXXX

# Riva ASR (the same NVIDIA key may be used for both models)
NVIDIA_API_KEY_ASR=nvapi-XXXXX
RIVA_SERVER=grpc.nvcf.nvidia.com:443
RIVA_FUNCTION_ID_PARAKEET=a9eeee8f-b509-4712-b19d-194361fa5f31
RIVA_FUNCTION_ID_WHISPER=b702f636-f60c-4a3d-a6f4-f3568c13bd7d

# Model Configuration
CHAT_MODEL_THINKING=z-ai/glm-5.2
CHAT_MODEL_FAST=nvidia/nvidia-nemotron-nano-9b-v2
FORMATTER_MODEL=meta/llama-3.1-70b-instruct
EMBEDDING_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v2

# Agent Configuration
TEMPERATURE=0.2
TOP_P=0.7
MAX_TOKENS=8192

# MongoDB (local Docker or MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=agent_knowledge_base

# Backend
HOST=127.0.0.1
PORT=9443

# NextAuth (Frontend)
NEXTAUTH_URL=http://localhost:3006
NEXTAUTH_SECRET=your-secret-here

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
